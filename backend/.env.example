DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=False
ALLOWED_HOSTS=.onrender.com,.railway.app,localhost,127.0.0.1

# Frontend deployment URL
FRONTEND_URL=https://auntorshoppingmall.vercel.app
CORS_ALLOWED_ORIGINS=https://auntorshoppingmall.vercel.app
CSRF_TRUSTED_ORIGINS=https://auntorshoppingmall.vercel.app

# Preferred production database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Optional MySQL fallback if you do not use DATABASE_URL
MYSQL_DATABASE=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_HOST=
MYSQL_PORT=3306

# Optional Cloudinary media storage
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional email settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@auntorshoppingmall.com

# Optional payment settings
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta